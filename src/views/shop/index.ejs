<%- include('../partials/head', { title }) %>
<%- include('../partials/nav', { q, cartCount, currentPath }) %>

<main class="container">
  <section class="hero">
    <div class="hero-card">
      <div class="hero-kicker">New season, new loot</div>
      <h1 class="hero-title">Your anime goods, but <span class="accent">extra sparkly</span>.</h1>
      <p class="hero-sub">
        Figures, mousepads, manga, light novels, and more — curated for collectors and cozy readers.
      </p>

      <div class="hero-cta">
        <a class="btn btn-primary" href="#categories">Browse categories</a>
        <a class="btn btn-ghost" href="#featured">Featured drops</a>
      </div>
    </div>

    <div class="hero-aside">
      <div class="stat">
        <div class="stat-num">Fast</div>
        <div class="stat-label">session cart</div>
      </div>
      <div class="stat">
        <div class="stat-num">Neon</div>
        <div class="stat-label">anime UI theme</div>
      </div>
      <div class="stat">
        <div class="stat-num">SQLite</div>
        <div class="stat-label">simple DB</div>
      </div>
    </div>
  </section>

  <section id="categories" class="section">
    <div class="section-head">
      <h2 class="section-title">Shop by section</h2>
      <div class="section-sub">Pick an aisle. The soundtrack starts automatically.</div>
    </div>

    <div class="grid cats">
      <% categories.forEach((c) => { %>
        <a class="card cat" href="/shop/c/<%= c.slug %>">
          <div class="cat-emoji"><%= c.emoji || '✦' %></div>
          <div class="cat-name"><%= c.name %></div>
          <div class="cat-cta">Explore →</div>
        </a>
      <% }) %>
    </div>
  </section>

  <section id="featured" class="section">
    <div class="section-head">
      <h2 class="section-title">Featured</h2>
      <div class="section-sub">A few favorites to start your haul.</div>
    </div>

    <div class="grid products">
      <% featured.forEach((p) => { %>
        <article class="card product">
          <a class="product-media" href="/shop/p/<%= p.slug %>">
            <img src="<%= p.image_url %>" alt="<%= p.name %>" loading="lazy" />
            <div class="product-badge"><%= p.category_emoji || '✦' %> <%= p.category_name %></div>
          </a>
          <div class="product-body">
            <a class="product-title" href="/shop/p/<%= p.slug %>"><%= p.name %></a>
            <div class="product-meta">
              <div class="price"><%= formatMoney(p.price_cents) %></div>
              <div class="stock <%= p.stock > 0 ? 'in' : 'out' %>">
                <%= p.stock > 0 ? `${p.stock} in stock` : "Sold out" %>
              </div>
            </div>

            <form class="product-actions" action="/cart/add" method="post">
              <input type="hidden" name="product_id" value="<%= p.id %>" />
              <input class="qty" type="number" name="qty" min="1" max="99" value="1" />
              <button class="btn btn-primary" type="submit" <%= p.stock <= 0 ? 'disabled' : '' %>>
                Add to cart
              </button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title">Search</h2>
      <div class="section-sub">Type something in the search box above to find items.</div>
    </div>

    <% if (q || category) { %>
      <div class="notice">
        Showing results
        <% if (q) { %> for <strong>"<%= q %>"</strong><% } %>
        <% if (category) { %> in <strong><%= category %></strong><% } %>.
        <a href="/shop">Clear</a>
      </div>

      <div class="grid products">
        <% products.forEach((p) => { %>
          <article class="card product">
            <a class="product-media" href="/shop/p/<%= p.slug %>">
              <img src="<%= p.image_url %>" alt="<%= p.name %>" loading="lazy" />
              <div class="product-badge"><%= p.category_emoji || '✦' %> <%= p.category_name %></div>
            </a>
            <div class="product-body">
              <a class="product-title" href="/shop/p/<%= p.slug %>"><%= p.name %></a>
              <div class="product-meta">
                <div class="price"><%= formatMoney(p.price_cents) %></div>
                <div class="stock <%= p.stock > 0 ? 'in' : 'out' %>">
                  <%= p.stock > 0 ? `${p.stock} in stock` : "Sold out" %>
                </div>
              </div>
              <form class="product-actions" action="/cart/add" method="post">
                <input type="hidden" name="product_id" value="<%= p.id %>" />
                <input class="qty" type="number" name="qty" min="1" max="99" value="1" />
                <button class="btn btn-primary" type="submit" <%= p.stock <= 0 ? 'disabled' : '' %>>
                  Add to cart
                </button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>

      <% if (products.length === 0) { %>
        <div class="empty">
          <div class="empty-title">No matches</div>
          <div class="empty-sub">Try a different keyword (or browse categories).</div>
        </div>
      <% } %>
    <% } else { %>
      <div class="empty">
        <div class="empty-title">Ready when you are</div>
        <div class="empty-sub">Search above, or jump into a category.</div>
      </div>
    <% } %>
  </section>
</main>

<%- include('../partials/footer') %>

