<%- include('../partials/head', { title }) %>
<%- include('../partials/nav', { cartCount: 0, currentPath }) %>

<main class="container">
  <section class="page-head">
    <h1 class="page-title">My Orders</h1>
    <div class="page-sub">Your purchase history.</div>
  </section>

  <section class="card" style="padding:14px">
    <% if (orders.length === 0) { %>
      <div class="empty" style="margin:0">
        <div class="empty-title">No orders yet</div>
        <div class="empty-sub">After you check out, your orders will appear here.</div>
      </div>
    <% } else { %>
      <div class="summary-lines">
        <% orders.forEach((o) => { %>
          <div class="summary-line">
            <div class="summary-name">
              <strong>Order #<%= o.id %></strong>
              <span class="muted">• <%= o.created_at %></span>
            </div>
            <div class="summary-money"><%= formatMoney(o.total_cents) %></div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<%- include('../partials/footer') %>
